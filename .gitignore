```gitignore
# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
venv/
env/
ENV/
.venv/

# =========================
# Environment Variables
# =========================
.env
.env.*

# =========================
# Jupyter Notebook
# =========================
.ipynb_checkpoints/

# =========================
# VS Code
# =========================
.vscode/

# =========================
# PyCharm
# =========================
.idea/

# =========================
# Logs
# =========================
*.log

# =========================
# Database Files
# =========================
*.db
*.sqlite3

# =========================
# ChromaDB / Vector DB
# =========================
# chroma_db/
# chromadb/
# vectorstore/
# db/

# =========================
# Uploaded Files
# =========================
uploads/
data/

# =========================
# Model Cache
# =========================
.cache/
huggingface/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Build Files
# =========================
build/
dist/
*.egg-info/

# =========================
# Testing
# =========================
.pytest_cache/
coverage/

# =========================
# Streamlit
# =========================
.streamlit/

# =========================
# Node Modules (if frontend exists)
# =========================
node_modules/

# =========================
# Temporary Files
# =========================
*.tmp
*.temp
```
